# Root-level ignores. frontend/ and backend/ have their own .gitignore for build artifacts.

# Environment files (never commit secrets)
.env
.env.*
!.env.example
!.env.local.example

# Local tooling / downloaded distributions
.tooling/

# OS / editor
.DS_Store
Thumbs.db
desktop.ini
.idea/
*.iml
.vscode/
