{
  "expo": {
    "name": "Quarterly",
    "slug": "the12weekyear",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "twelveweekyear",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "com.twelveweekyear.app",
      "adaptiveIcon": {
        "backgroundColor": "#0b0b0c",
        "foregroundImage": "./assets/images/adaptive-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/logo-black.png",
          "imageWidth": 180,
          "dark": {
            "backgroundColor": "#0b0b0c",
            "image": "./assets/images/logo-white.png"
          }
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "TodayHabits",
              "label": "Today's habits",
              "description": "Your habits for today",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "previewImage": "./assets/images/icon.png",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "Quarter",
              "label": "Quarter progress",
              "description": "Your current quarter score",
              "minWidth": "140dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "previewImage": "./assets/images/icon.png",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "Week",
              "label": "This week",
              "description": "This week's goal and habits",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "previewImage": "./assets/images/icon.png",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "Quote",
              "label": "Quote of the day",
              "description": "A daily bit of motivation",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "previewImage": "./assets/images/icon.png",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "TodayProgress",
              "label": "Today's progress",
              "description": "How many of today's habits you've completed",
              "minWidth": "140dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "previewImage": "./assets/images/icon.png",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "QuarterCountdown",
              "label": "Quarter countdown",
              "description": "Days left in your current quarter",
              "minWidth": "140dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "previewImage": "./assets/images/icon.png",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "Streak",
              "label": "Habit streak",
              "description": "Your current perfect-day streak",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "previewImage": "./assets/images/icon.png",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      "expo-sharing",
      "expo-quick-actions"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9b5ebb9f-025f-4cee-ac96-b1945426eeaf"
      }
    },
    "owner": "cab1234567s-team"
  }
}
