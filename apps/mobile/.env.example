# Base URL of the Spring Boot API. Must be reachable FROM THE PHONE running Expo Go.
#
#  - Deployed backend (recommended for device testing): https://twelveweekyear-api.onrender.com
#  - Local backend: use your laptop's LAN IP (e.g. http://192.168.1.20:8080), NOT localhost —
#    "localhost" on the phone means the phone itself. Phone and laptop must share a network.
EXPO_PUBLIC_API_BASE_URL=https://twelveweekyear-api.onrender.com
