# Copy to .env and fill in real values. NEVER commit .env.
# These map 1:1 to the ${...} placeholders in application.yml.

# --- Database (Supabase Postgres) ---
# From Supabase: Project Settings -> Database -> Connection string (use the pooled "Session" URI).
# Convert the URI to JDBC form, e.g.:
#   jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=jdbc:postgresql://localhost:5432/twelveweekyear
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Hibernate schema strategy: update | validate | none  (dev default: update)
JPA_DDL_AUTO=update

# --- Server ---
SERVER_PORT=8080

# --- CORS (comma-separated browser origins allowed to call the API) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Auth / JWT ---
# HS256 signing secret. MUST be at least 32 bytes. Generate a strong random value for production,
# e.g.  openssl rand -base64 48
JWT_SECRET=dev-only-insecure-secret-change-me-in-production-0123456789
# Token lifetimes. Simple duration format: s, m, h, d.
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# --- OTP (email verification + password reset) ---
OTP_LENGTH=6
OTP_EXPIRY=5m
OTP_RESEND_COOLDOWN=120s
OTP_MAX_ATTEMPTS=5

# --- Email delivery ---
# provider: "log" (prints OTP to server logs, for dev) or "resend"
EMAIL_PROVIDER=log
# From address. For Resend, use onboarding@resend.dev until you verify your own domain.
MAIL_FROM=The 12 Week Year <onboarding@resend.dev>
# Required only when EMAIL_PROVIDER=resend. Get it from https://resend.com/api-keys
RESEND_API_KEY=
